{
  "name": "alaudaebot",
  "displayName": "AlaudaeBot - Telegram Bridge",
  "description": "通过 Telegram 与 Antigravity Agent 对话",
  "version": "0.0.1",
  "publisher": "alaudae",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "alaudaebot.start",
        "title": "AlaudaeBot: 启动"
      },
      {
        "command": "alaudaebot.stop",
        "title": "AlaudaeBot: 停止"
      },
      {
        "command": "alaudaebot.status",
        "title": "AlaudaeBot: 状态"
      },
      {
        "command": "alaudaebot.configure",
        "title": "AlaudaeBot: 配置"
      },
      {
        "command": "alaudaebot.toggle",
        "title": "AlaudaeBot: 切换启停"
      },
      {
        "command": "alaudaebot.newChat",
        "title": "AlaudaeBot: 新建对话"
      },
      {
        "command": "alaudaebot.reconnect",
        "title": "AlaudaeBot: 重新连接（切换窗口）"
      }
    ],
    "configuration": {
      "title": "AlaudaeBot",
      "properties": {
        "alaudaebot.telegramBotToken": {
          "type": "string",
          "description": "Telegram Bot Token (从 @BotFather 获取)",
          "default": ""
        },
        "alaudaebot.allowedUsers": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "允许使用的 Telegram 用户 ID 列表",
          "default": []
        },
        "alaudaebot.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "随 Antigravity 启动自动连接"
        },
        "alaudaebot.cdpPort": {
          "type": "number",
          "default": 9222,
          "description": "Antigravity CDP 端口"
        },
        "alaudaebot.preventSleep": {
          "type": "boolean",
          "default": true,
          "description": "桥接运行时阻止系统休眠"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p .",
    "check": "tsc -p . --noEmit",
    "bundle": "npm run clean && node esbuild.js",
    "package": "npm run bundle && npx vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "grammy": "^1.41.1",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "playwright-core": "^1.58.2"
  }
}